#!/bin/bash
#PBS -N AutoNets_Single
#PBS -q cpu
#PBS -l select=1:ncpus=32:mem=32gb
#PBS -l walltime=250:00:00
#PBS -o logs/
#PBS -e logs/

cd $PBS_O_WORKDIR

module purge
module load compiler/anaconda3-23.07.0

source venv/bin/activate

python save_autonomous_networks.py simple_single

echo "Finished autonomous network generation at $(date)"