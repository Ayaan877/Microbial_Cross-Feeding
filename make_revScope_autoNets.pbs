#!/bin/bash
#PBS -N RevScope_AutoNets
#PBS -q cpu
#PBS -l select=1:ncpus=32:mem=16gb
#PBS -l walltime=10:00:00
#PBS -o logs/
#PBS -e logs/

cd $PBS_O_WORKDIR

module purge
module load compiler/anaconda3-23.07.0

source venv/bin/activate

# arg1 = dataset id (for output filename)

python build_revScope_autoNets.py 1

echo "Finished revScope autonomous network generation at $(date)"