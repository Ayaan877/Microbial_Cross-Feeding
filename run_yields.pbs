#!/bin/bash
#PBS -N Yields_BP
#PBS -q cpu
#PBS -l select=1:ncpus=32:mem=32gb
#PBS -l walltime=24:00:00
#PBS -o logs/
#PBS -e logs/

cd $PBS_O_WORKDIR

module purge
module load compiler/anaconda3-23.07.0

source venv/bin/activate

export NUM_WORKERS=32

# arg1 = batch or single
# arg2 = NP or P
# arg3 = dataset number

python get_yields.py batch P 6 1

echo "Finished yield calculation at $(date)"
